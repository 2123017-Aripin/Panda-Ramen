# Ganti dengan Client Key & Server Key dari dashboard.midtrans.com
# Untuk testing: gunakan environment "Sandbox" (key diawali SB-Mid-...)
# Untuk live/produksi: gunakan environment "Production"

MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# Port server backend
PORT=3000

# Base URL backend ini (dipakai untuk callback finish/error/notification)
# Saat development lokal dengan emulator Android: biarkan default
# Saat pakai HP fisik/production: ganti sesuai domain/IP publik
BASE_URL=http://localhost:3000
